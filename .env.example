# Automated Log Triager & Diagnostic Agent - Environment Variables

# Google API Key from https://aistudio.google.com/
GOOGLE_API_KEY=your_key_here

# Gemini Model to use
GEMINI_MODEL_NAME=gemini-2.5-flash

# Vector DB Configuration (Chroma Cloud - see https://www.trychroma.com)
CHROMA_API_KEY=your_chroma_cloud_api_key
CHROMA_TENANT=your_chroma_cloud_tenant_id
CHROMA_DATABASE=log-triager

# Environment (development/production)
ENVIRONMENT=development
